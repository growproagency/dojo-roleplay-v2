# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real secrets

NODE_ENV=development
PORT=3001

# Supabase — get from your project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# JWT — used to sign Vapi session tokens (any random secret string)
JWT_SECRET=your-jwt-secret-here

# OpenAI — for AI call scoring
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Vapi — for AI voice calls (optional; leave blank if not using)
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_URL=

# n8n / HighLevel automation webhook
AUTOMATION_WEBHOOK_SECRET=replace-with-random-secret
